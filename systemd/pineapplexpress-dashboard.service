[Unit]
Description=PineAppleXpress Dashboard
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pineapple
WorkingDirectory=/home/pineapple/pineapplexpress/app
ExecStart=/home/pineapple/pineapplexpress/.venv/bin/gunicorn --workers 1 --bind 0.0.0.0:8080 app:app
Restart=on-failure
RestartSec=3
NoNewPrivileges=true
PrivateTmp=true

[Install]
WantedBy=multi-user.target
